# Supabase — 공개 클라이언트 설정
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — 서버 전용 Service Role Key. 브라우저에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# Toss Payments — 공개 클라이언트 키
NEXT_PUBLIC_TOSS_CLIENT_KEY=

# Toss Payments — 서버 전용 Secret Key
TOSS_SECRET_KEY=

# OpenAI — 운영 리포트 생성 경로에서 사용
OPENAI_API_KEY=

# Telegram — 결제/리포트 알림용 서버 전용 설정
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 테스트 전용. 운영/데모 Supabase와 분리된 프로젝트에서만 사용.
NEXT_PUBLIC_E2E_MOCK=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_SUPABASE_PROJECT_REF=

# 레거시 Gemini 도구 전용. 운영 리포트 생성 경로에서는 사용하지 않음.
GEMINI_API_KEY=
